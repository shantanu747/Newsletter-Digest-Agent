<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title>Newsletter Digest</title></head>
<body style="font-family: Georgia, serif; max-width: 680px; margin: 0 auto; padding: 24px; color: #222;">

  <!-- Header -->
  <div style="border-bottom: 2px solid #333; margin-bottom: 24px; padding-bottom: 12px;">
    <h1 style="margin: 0; font-size: 24px;">📬 Newsletter Digest</h1>
    <p style="margin: 4px 0 0; color: #666; font-size: 14px;">
      {{ run_date.strftime('%A, %B %-d, %Y') }} · {{ total_summarized }} newsletter{{ 's' if total_summarized != 1 }} summarized
    </p>
  </div>

  <!-- Entries -->
  {% for entry in entries %}
  <div style="margin-bottom: 32px;">
    <p style="margin: 0 0 2px; font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.05em;">
      {{ entry.summary.sender }}
    </p>
    <h2 style="margin: 0 0 12px; font-size: 18px;">{{ entry.summary.subject }}</h2>
    <div style="line-height: 1.7; font-size: 15px;">
      {{ entry.summary.summary_text | nl2br }}
    </div>
    {% if entry.images %}
    <div style="margin: 16px 0; display: flex; flex-wrap: wrap; gap: 8px;">
      {% for img_src in entry.images %}
      {% set safe_src = img_src | safe_url %}{% if safe_src %}<img src="{{ safe_src }}" style="max-width: 100%; height: auto; border-radius: 4px;" loading="lazy" alt="">{% endif %}
      {% endfor %}
    </div>
    {% endif %}
    {% if entry.links %}
    <div style="margin-top: 16px; padding: 12px 16px; background: #f8f9fa; border-radius: 4px;">
      <p style="margin: 0 0 8px; font-size: 12px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.05em; color: #666;">Further Reading</p>
      <ul style="margin: 0; padding-left: 18px; list-style: disc;">
        {% for link in entry.links %}
        <li style="margin-bottom: 6px; font-size: 14px; line-height: 1.5;">
          <a href="{{ link.url | safe_url }}" style="color: #1a73e8; text-decoration: none;">{{ link.title }}</a>
          {% if link.context %}<span style="color: #666; font-size: 12px; display: block; margin-top: 2px;">{{ link.context }}</span>{% endif %}
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
    {% if entry.original_email_url %}
    <p style="margin: 12px 0 0;"><a href="{{ entry.original_email_url | safe_url }}" style="color: #1a73e8; font-size: 13px;">View original →</a></p>
    {% endif %}
  </div>
  {% if not loop.last %}<hr style="border: none; border-top: 1px solid #eee; margin: 24px 0;">{% endif %}
  {% endfor %}

  <!-- Failed newsletters -->
  {% if failed_subjects %}
  <div style="margin-top: 32px; padding: 12px 16px; background: #fff8e1; border-left: 3px solid #f9a825; font-size: 13px; color: #555;">
    <strong>Could not summarize:</strong> {{ failed_subjects | join(', ') }}
  </div>
  {% endif %}

  <!-- Footer -->
  <div style="margin-top: 40px; padding-top: 16px; border-top: 1px solid #eee; font-size: 12px; color: #aaa; text-align: center;">
    Generated by Newsletter Digest Agent
  </div>

</body>
</html>
